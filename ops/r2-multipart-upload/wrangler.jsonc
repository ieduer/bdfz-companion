{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "bdfz-companion-r2-upload-temp",
  "main": "../../scripts/r2-multipart-worker.mjs",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "observability": {
    "enabled": false
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "blog-images"
    }
  ]
}
